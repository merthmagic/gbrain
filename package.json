{
  "name": "gbrain",
  "version": "0.1.0",
  "description": "A local-first knowledge base CLI built with Bun, TypeScript, and SQLite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/merthmagic/gbrain.git"
  },
  "homepage": "https://github.com/merthmagic/gbrain#readme",
  "bugs": {
    "url": "https://github.com/merthmagic/gbrain/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile --outfile dist/gbrain src/cli.ts"
  },
  "bin": {
    "gbrain": "./bin/gbrain"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "examples/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "dependencies": {
    "gray-matter": "^4.0.3",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
